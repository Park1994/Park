package com.setexam;

import java.util.*;

class Person {
	String name;
	int age;
	
	public Person(String name, int age) {
		this.name = name;
		this.age = age;
	}
	
	@Override
	public String toString() {
		return name + ": " + age;
	}
}
public class HashSetEx02 {

	public static void main(String[] args) {

		HashSet set = new HashSet<>();
		set.add("abc");
		set.add("adc");
		set.add(new Person("David", 0))
	}

}
