package com.collectionexam;

import java.util.*;
public class CollectionExam10 {

	private Vector<Nation> v = new Vector<Nation>();
	private Scanner sc = new Scanner(System.in);
	
	public CollectionExam10() {
	
		v.add(new Nation("멕시코", "멕시코시티"));
		v.add(new Nation("스페인", "리스본"));
		v.add(new Nation("프랑스", "파리"));
		v.add(new Nation("영국", "런던"));
		v.add(new Nation("그리스", "아테네"));
		v.add(new Nation("독일", "베를린"));
		v.add(new Nation("일본", "도쿄"));
		v.add(new Nation("중국", "베이징"));
		v.add(new Nation("러시아", "모스크바"));
	}
	
	public void error(String msg) {
		System.out.println(msg);
	}
	
	public void run() {
		System.out.println("수도 맞추기 게임을 시작합니다.");
		while(true) {
			System.out.print("입력: 1, 퀴즈: 2, 종료: 3 >> ");
			int menu = sc.nextInt();
			switch(menu) {
			case 1:
				input();
				break;
			case 2:
				quiz();
				break;
			case 3:
				finish();
				return;
			default :
				error("잘못된 입력입니다.");
			}
		}
	}
	
	public boolean contains(String country) {
		for(int i = 0; i < v.size(); i++) {
			if(v.get(i).getCountry().equals(country)) {
				// 사용자가 입력한 나라가 이미 있다면
				return true;
			}
		}
		return false;
	}
	
	public void input() {
		int n = v.size();
		System.out.println("현재 " + n + "개의 나라와 수도가 입력되어 있습니다.");
		n++;
		while(true) {
			System.out.print("나라와 수도입력 " + n + ">>");
			String country = sc.next();
			if(country.equals("그만")) {
				break;
			}
			String capital = sc.next();
		}
	}
	
	public void quiz() {
		
	}
	
	public void finish() {
		System.out.println("게임을 종료합니다.");
		return;
	}
	
	public static void main(String[] args) {

		new CollectionExam10().run();
	}

}
