package com.collectionexam;

import java.util.*;
public class CollectionEx01 {

	public static void main(String[] args) {

		Scanner sc = new Scanner(System.in);
		
		Vector<Object> v = new Vector<>();
		
		while(true) {
			System.out.print("정수: ");
			int n = sc.nextInt();
			if(n == -1) {
				System.out.println("프로그램을 종료합니다.");
				break;
			}
			v.add(n);
		}
	}

}
