package com.collectionexam;

import java.util.*;
public class CollectionExam08 {

	private Scanner sc = new Scanner(System.in);
	private HashMap<String, Integer> map = new HashMap<String, Integer>();
	
	public CollectionExam08() {
		
	}
	
	public void run() {
		System.out.println("포인트 관리 프로그램입니다.");
		
		while(true) {
			System.out.print("이름과 포인트 입력: ");
			String name = sc.next();
			if(name.equals("그만")) {
				System.out.println("프로그램을 종료합니다.");
				break;
			}
			int point = sc.nextInt(); // 포인트 입력
			
			Integer n = map.get(name); // 이름으로 포인트를 검색
			if(n != null) { // 포인터가 있다면
				point += n; // 포인터를 누적함
			}
			
			// 맵에 저장
			map.put(name, point); // 이름과 포인트 갱신
		}
	}
	
	public void print() {
		
	}
	
	public static void main(String[] args) {

		new CollectionExam08().run();
	
	}

}
