package com.mapex;

/*
 * 	TreeMap
 * 	-정렬된 상태로 데이터를 추가함
 * 	-SortedMap<K, V> subMap (K from Key, K toKey)
 * 		부분테이터를 추출할 수 있다.
 * 		fromKey: 키를 포함하고
 * 		toKey: 키를 포함하지 않는다.
 */

import java.util.*;
public class TreeMapEx01 {

	public static void main(String[] args) {

		TreeMap<String, String> map = new TreeMap<>();
		map.put("만화", "마녀배달부 키키");
		map.put("호러", "스크림");
	}

}
